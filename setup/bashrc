alias view_jobs='squeue -u $USER'

alias home='cd ~'

alias copy_to_eos='/path/to/copy_to_eos'

sims() {
    SIMS_DIR_FILE="$HOME/.sims_dir"

    if [[ "$1" == "--set_dir" ]]; then
        if [[ -z "$2" ]]; then
            echo "$PWD" > "$SIMS_DIR_FILE"
            echo "Simulation directory set to current directory: $PWD"
        else
            if [[ -d "$2" ]]; then
                echo "$2" > "$SIMS_DIR_FILE"
                echo "Simulation directory set to: $2"
            else
                echo "Error: Directory '$2' does not exist."
                return 1
            fi
        fi
    else
        if [[ -f "$SIMS_DIR_FILE" ]]; then
            SIM_DIR=$(cat "$SIMS_DIR_FILE")
            if [[ -d "$SIM_DIR" ]]; then
                cd "$SIM_DIR" || return
                echo "Changed to simulation directory: $SIM_DIR"
            else
                echo "Error: Saved simulation directory '$SIM_DIR' does not exist."
                return 1
            fi
        else
            echo "No simulation directory set. Use 'sims --set_dir' to set one."
            return 1
        fi
    fi
}

jobcd() {
    local jobname="$1"

    # Get the most recent job ID with that name
    local jobid
    jobid=$(squeue -u "$USER" -o "%.18i %.100j" | awk -v name="$jobname" '$2==name {print $1}' | tail -n 1)

    if [ -z "$jobid" ]; then
        echo "No running job found with name: $jobname"
        return 1
    fi

    # Get the working directory
    local workdir
    workdir=$(scontrol show job "$jobid" | awk -F= '/WorkDir/ {print $2}' | head -n 1)

    if [ -z "$workdir" ]; then
        echo "Could not determine WorkDir for job $jobid"
        return 1
    fi

    cd "$workdir" || return
}
